# =====================================================================
# Python (backend)
# =====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging / build artifacts
*.egg
*.egg-info/
build/
dist/
pip-wheel-metadata/

# Test / lint / type caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml

# =====================================================================
# Node / Vue / Vite (frontend)
# =====================================================================
node_modules/
dist/
dist-ssr/
.vite/
*.local
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Package manager state we don't want to commit
.npm
.yarn/cache
.yarn/install-state.gz
.yarn/build-state.yml
.pnp.*

# =====================================================================
# Generated artifacts
# =====================================================================
# Generated from the backend's OpenAPI via scripts/generate-client.sh.
# Checked in so the frontend Dockerfile builds without a running backend.
# Regenerate after backend schema changes and commit the result.
#frontend/src/api/schema.d.ts

# =====================================================================
# Environment / secrets
# =====================================================================
.env
.env.*
!.env.example

# =====================================================================
# Database dumps from scripts/backup-db.sh
# =====================================================================
backups/

# =====================================================================
# Local data / uploads
# =====================================================================
data/
# Local sound library (Explore → Local tab). Bind-mounted read-only into the
# backend; the user drops <Category>/<name>.mp3 folders here. Ignore the audio
# but keep the folder + docs tracked so the mount target exists.
sounds/*
!sounds/.gitkeep
!sounds/README.md
# Sample / scratch audio at repo root (real uploads live in the Docker
# volume `sounddata_dev`, not the repo).
/*.mp3
/*.wav

# =====================================================================
# Editor / IDE
# =====================================================================
.idea/
.vscode/
*.swp
*.swo
*.swn
*~

# =====================================================================
# OS detritus
# =====================================================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
desktop.ini

# =====================================================================
# Docker
# =====================================================================
docker-compose.override.yml

# =====================================================================
# Misc / scratch
# =====================================================================
*.log
wip
.claude/
